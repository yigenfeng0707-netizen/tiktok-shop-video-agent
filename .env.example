# ===== LLM 脚本生成（OpenAI 兼容 API）=====
# 脚本生成 Agent 使用的 LLM 服务，不配置则回退 mock 模板填充
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# ===== 数字人视频生成 =====
# HeyGen 数字人 API（优先使用），申请入口：https://app.heygen.com/
HEYGEN_API_KEY=
# 腾讯智影数字人 API（备选），申请入口：https://zenvideo.tencent.com/
TENCENT_ZY_API_KEY=
TENCENT_ZY_SECRET_ID=
TENCENT_ZY_SECRET_KEY=
TENCENT_ZY_REGION=ap-guangzhou

# ===== 数据复盘 =====
# TikTok Research API，用于采集真实视频指标，申请入口：https://developers.tiktok.com/
TIKTOK_API_KEY=

# ===== 业务 API =====
# 自定义业务 API 端点与鉴权 Key（可选，用于扩展集成）
USER_API_ENDPOINT=
API_KEY=

# ===== 服务运行配置 =====
HOST=0.0.0.0
PORT=8000
